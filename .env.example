# Local development on the host uses localhost. In Docker production, use host postgres.
DATABASE_URL="postgresql://image_studio:image_studio@localhost:5432/image_studio?schema=public"

# Public app URL used by links and deployment docs.
APP_URL="http://localhost:3000"

# Server-only auth settings. Replace in production.
JWT_SECRET="replace-with-a-long-random-secret"
SESSION_COOKIE_NAME="image_studio_session"

# First user bootstrap is interactive: when the database has no users,
# the registration form creates the first account as ADMIN.
ALLOW_REGISTRATION="true"

# Server-only image provider defaults. Do not prefix with NEXT_PUBLIC.
# Users add their own API keys in Personal Settings; this key is only a global default record.
IMAGE_PROVIDER="openai-compatible"
IMAGE_API_BASE_URL="https://api.openai.com"
IMAGE_GENERATION_PATH="/v1/images/generations"
IMAGE_EDIT_PATH="/v1/images/edits"
IMAGE_API_KEY="server-only-secret"
IMAGE_DEFAULT_MODEL="gpt-image-2"
IMAGE_DEFAULT_SIZE="1024x1024"
IMAGE_DEFAULT_QUALITY="auto"
IMAGE_REQUEST_TIMEOUT_MS="180000"
SETTINGS_ENCRYPTION_KEY="replace-with-a-long-random-secret"

# Local file storage.
UPLOAD_DIR="/data/uploads"
MAX_UPLOAD_MB="20"
